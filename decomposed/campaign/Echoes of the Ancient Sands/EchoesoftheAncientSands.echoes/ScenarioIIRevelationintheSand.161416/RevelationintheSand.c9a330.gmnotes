{"id":"06e1d491-eb7f-4b52-937c-ca137062e625","type":"ScenarioReference","class":"Mythos","tokens":{"front":{"Cultist":{"modifier":-999,"description":"-X. X is the number of doom on cards other than the agenda in play."},"Skull":{"modifier":-2,"description":"-2. "},"Tablet":{"modifier":-1,"description":"-1. Reveal another token. If you fail, lose 1 resource."},"Elder Thing":{"modifier":-4,"description":"-4. If you fail during an <b>Excavate</b> attempt, remove the Mound of Dirt at your location from the game."}},"back":{"Cultist":{"modifier":-999,"description":"-X. X is the number of doom on enemies in play plus the number of the current Agenda."},"Skull":{"modifier":-3,"description":"-3. If you fail and if there is an enemy at your location, take 1 damage."},"Tablet":{"modifier":-999,"description":"Reveal another token. If you fail, lose 2 resources."},"Elder Thing":{"modifier":-4,"description":"-4. If you fail during <b>Excavate</b>, remove the Mound of Dirt at your location from the game."}}},"TtsZoopGuid":"06e1d491-eb7f-4b52-937c-ca137062e625"}
